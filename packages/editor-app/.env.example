# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key

# 카카오
NEXT_PUBLIC_KAKAO_MAP_API_KEY=your-kakao-map-key
KAKAO_REST_API_KEY=your-kakao-rest-key

# 토스페이먼츠
TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...
TOSS_WEBHOOK_SECRET=your-webhook-secret

# Cloudflare
CLOUDFLARE_API_TOKEN=your-cf-token
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_PAGES_PROJECT=homepage-builder-sites

# Unsplash
UNSPLASH_ACCESS_KEY=your-unsplash-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_DOMAIN=yourdomain.com

# 도메인 검증 (랜덤 시크릿 문자열 — openssl rand -hex 32)
DOMAIN_VERIFICATION_SECRET=your-random-secret
