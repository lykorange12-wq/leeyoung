{
  "name": "homepage-builder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "dev:editor": "turbo run dev --filter=editor-app",
    "dev:renderer": "turbo run dev --filter=site-renderer",
    "db:types": "turbo run db:types --filter=editor-app"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "vercel": "^50.0.0",
    "typescript": "^5.7.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
